      "role": "assistant",
      "name": "PlanningAgent",
      "tool_calls": [
        {
          "id": "call_skill_select_001",
          "type": "function",
          "function": {
            "name": "skill_select",
            "arguments": "{\"request\":\"Connect a new embodied agent into the network subnet.\",\"available_skills\":[{\"name\":\"ACN\",\"description\":\"Process of connecting embodied agents to the network.\"}]}"
          }
        }
      ]
